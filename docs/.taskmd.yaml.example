# Example .taskmd.yaml configuration file
#
# This file can be placed in:
#   - Project directory (./.taskmd.yaml) - for project-specific settings
#   - Home directory (~/.taskmd.yaml) - for global user settings
#
# Precedence order (highest to lowest):
#   1. Command-line flags (explicit user intent)
#   2. Project-level .taskmd.yaml (project-specific defaults)
#   3. Global ~/.taskmd.yaml (user-wide defaults)
#   4. Built-in defaults (fallback)

# Default directory to search for task files
# This sets the default value for the --dir flag
dir: ./tasks

# Web server configuration
web:
  # Default port for the web dashboard server
  # This sets the default value for the --port flag in 'taskmd web start'
  port: 8080

  # Automatically open browser when starting the web server
  # This sets the default value for the --open flag in 'taskmd web start'
  auto_open_browser: false

# Enable or disable task worklogs
# When true (default), agents are encouraged to create and maintain worklog files
# alongside tasks to record progress, decisions, and blockers.
# Set to false to disable worklog behavior in agent workflows.
worklogs: true

# Sync configuration - fetch tasks from external sources
# Run 'taskmd sync' to pull tasks, or 'taskmd sync --dry-run' to preview changes.
# sync:
#   sources:
#     # GitHub Issues source
#     - name: github
#       project: "owner/repo"            # GitHub owner/repo
#       token_env: GITHUB_TOKEN          # Env var holding a GitHub personal access token
#       output_dir: ./tasks/github       # Where to write synced task files
#       field_map:
#         status:
#           open: pending
#           closed: completed
#         labels_to_tags: true
#         assignee_to_owner: true
#       filters:
#         state: open                    # Only sync open issues
#
#     # Jira Cloud source
#     - name: jira
#       project: "PROJ"                  # Jira project key
#       base_url: https://myteam.atlassian.net  # Jira Cloud instance URL
#       token_env: JIRA_API_TOKEN        # Env var holding a Jira API token
#       user_env: JIRA_USER_EMAIL        # Env var holding your Jira account email
#       output_dir: ./tasks/jira
#       field_map:
#         status:
#           To Do: pending
#           In Progress: in-progress
#           Done: completed
#         priority:
#           High: high
#           Medium: medium
#           Low: low
#         labels_to_tags: true
#         assignee_to_owner: true
#       filters:
#         jql: 'status != "Done"'        # Additional JQL filter (ANDed with project)

# Note: Only 'dir', 'web.port', 'web.auto_open_browser', 'worklogs', and 'sync' are
# supported in config files. Other flags like 'format', 'verbose', and 'quiet' are
# intentionally CLI-only to keep config files focused on project-specific settings
# rather than per-invocation preferences.
